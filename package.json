{
  "name": "aura-finance",
  "version": "1.0.0",
  "description": "Aura Finance — Institutional Liquidity Layer for Bitcoin on OP_NET",
  "private": true,
  "scripts": {
    "dev": "npx serve public -p 3000",
    "build": "echo 'Static site — no build step required'",
    "deploy": "vercel --prod",
    "compile:contract": "opnet compile ./contracts/AuraStaking.ts",
    "deploy:testnet": "opnet deploy --network testnet --contract ./dist/AuraStaking.wasm",
    "verify:testnet": "opnet verify --network testnet"
  },
  "dependencies": {
    "@btc-vision/btc-runtime": "^1.0.0",
    "@btc-vision/opnet": "^1.0.0",
    "as-bignum": "^0.2.0"
  },
  "devDependencies": {
    "@btc-vision/opnet-cli": "^1.0.0",
    "assemblyscript": "^0.27.0",
    "serve": "^14.2.0",
    "vercel": "^37.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/aura-finance.git"
  },
  "keywords": ["defi", "bitcoin", "opnet", "staking", "web3"],
  "license": "MIT"
}
